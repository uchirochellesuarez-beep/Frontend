const express = require('express');
const router = express.Router();
const pool = require('../db');

// GET /api/loans - Get all loans with filtering
router.get('/', async (req, res) => {
  try {
    const { farmer_id, status, start_date, end_date, limit = 100 } = req.query;
    
    let query = `
      SELECT 
        l.*,
        f.full_name,
        f.reference_number,
        a.full_name as approved_by_name
      FROM loans l
      JOIN farmers f ON l.farmer_id = f.id
      LEFT JOIN farmers a ON l.approved_by = a.id
      WHERE 1=1
    `;
    const params = [];
    
    if (farmer_id) {
      query += ' AND l.farmer_id = ?';
      params.push(farmer_id);
    }
    
    if (status) {
      query += ' AND l.status = ?';
      params.push(status);
    }
    
    if (start_date) {
      query += ' AND l.application_date >= ?';
      params.push(start_date);
    }
    
    if (end_date) {
      query += ' AND l.application_date <= ?';
      params.push(end_date);
    }
    
    query += ' ORDER BY l.application_date DESC LIMIT ?';
    params.push(parseInt(limit));
    
    const [loans] = await pool.execute(query, params);
    res.json({ success: true, loans });
  } catch (error) {
    console.error('Error fetching loans:', error);
    res.status(500).json({ success: false, message: 'Failed to fetch loans' });
  }
});

// GET /api/loans/farmer/:farmerId - Get loans for specific farmer
router.get('/farmer/:farmerId', async (req, res) => {
  try {
    const { farmerId } = req.params;
    
    const [loans] = await pool.execute(
      `SELECT * FROM loans 
       WHERE farmer_id = ? 
       ORDER BY application_date DESC`,
      [farmerId]
    );
    
    res.json({ success: true, loans });
  } catch (error) {
    console.error('Error fetching farmer loans:', error);
    res.status(500).json({ success: false, message: 'Failed to fetch loans' });
  }
});

// GET /api/loans/:id - Get specific loan details
router.get('/:id', async (req, res) => {
  try {
    const { id } = req.params;
    
    const [loans] = await pool.execute(
      `SELECT 
        l.*,
        f.full_name,
        f.reference_number,
        a.full_name as approved_by_name
       FROM loans l
       JOIN farmers f ON l.farmer_id = f.id
       LEFT JOIN farmers a ON l.approved_by = a.id
       WHERE l.id = ?`,
      [id]
    );
    
    if (loans.length === 0) {
      return res.status(404).json({ success: false, message: 'Loan not found' });
    }
    
    // Get payment history
    const [payments] = await pool.execute(
      `SELECT * FROM loan_payments 
       WHERE loan_id = ? 
       ORDER BY payment_date DESC`,
      [id]
    );
    
    res.json({ 
      success: true, 
      loan: loans[0],
      payments 
    });
  } catch (error) {
    console.error('Error fetching loan details:', error);
    res.status(500).json({ success: false, message: 'Failed to fetch loan details' });
  }
});

// POST /api/loans - Create new loan application
router.post('/', async (req, res) => {
  try {
    const { 
      farmer_id, 
      loan_amount, 
      interest_rate, 
      loan_purpose, 
      application_date,
      payment_term,
      remarks 
    } = req.body;
    
    console.log('Received loan application:', req.body);
    
    if (!farmer_id || !loan_amount || !application_date) {
      return res.status(400).json({ 
        success: false, 
        message: 'Missing required fields: farmer_id, loan_amount, application_date' 
      });
    }
    
    const [result] = await pool.execute(
      `INSERT INTO loans 
       (farmer_id, loan_amount, interest_rate, loan_purpose, application_date, 
        remaining_balance, payment_term, remarks, status)
       VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'pending')`,
      [
        farmer_id, 
        loan_amount, 
        interest_rate || 0,
        loan_purpose,
        application_date,
        loan_amount, // Initially, remaining balance equals loan amount
        payment_term,
        remarks || null
      ]
    );
    
    // Log activity
    try {
      const [farmer] = await pool.execute('SELECT full_name FROM farmers WHERE id = ?', [farmer_id]);
      await pool.execute(
        `INSERT INTO activity_logs (farmer_id, activity_type, activity_description, metadata)
         VALUES (?, 'loan_application', ?, ?)`,
        [
          farmer_id, 
          `${farmer[0]?.full_name} applied for a loan of ₱${loan_amount}`,
          JSON.stringify({ loan_id: result.insertId, amount: loan_amount, purpose: loan_purpose })
        ]
      );
    } catch (logErr) {
      console.error('Error logging loan application:', logErr);
    }
    
    res.json({ success: true, id: result.insertId, message: 'Loan application submitted successfully' });
  } catch (error) {
    console.error('Error creating loan:', error);
    console.error('Error details:', error.message, error.stack);
    res.status(500).json({ success: false, message: 'Failed to create loan application', error: error.message });
  }
});

// PUT /api/loans/:id/approve - Approve loan
router.put('/:id/approve', async (req, res) => {
  try {
    const { id } = req.params;
    const { approved_by, due_date, remarks } = req.body;
    
    console.log('Approving loan:', { id, approved_by, due_date, remarks });
    
    const approval_date = new Date().toISOString().split('T')[0];
    
    await pool.execute(
      `UPDATE loans 
       SET status = 'approved', approval_date = ?, approved_by = ?, due_date = ?, remarks = ?
       WHERE id = ?`,
      [approval_date, approved_by || null, due_date, remarks || null, id]
    );
    
    // Get loan details for activity log
    const [loan] = await pool.execute(
      `SELECT l.*, f.full_name FROM loans l 
       JOIN farmers f ON l.farmer_id = f.id 
       WHERE l.id = ?`,
      [id]
    );
    
    // Log approval activity
    if (loan.length > 0) {
      try {
        await pool.execute(
          `INSERT INTO activity_logs (farmer_id, activity_type, activity_description, metadata)
           VALUES (?, 'loan_approval', ?, ?)`,
          [
            loan[0].farmer_id, 
            `Loan application of ${loan[0].full_name} for ₱${loan[0].loan_amount} was approved`,
            JSON.stringify({ loan_id: id, amount: loan[0].loan_amount, approved_by })
          ]
        );
      } catch (logErr) {
        console.error('Error logging loan approval:', logErr);
      }
    }
    
    res.json({ success: true, message: 'Loan approved successfully' });
  } catch (error) {
    console.error('Error approving loan:', error);
    console.error('Error details:', error.message);
    console.error('Error stack:', error.stack);
    res.status(500).json({ success: false, message: 'Failed to approve loan', error: error.message });
  }
});

// PUT /api/loans/:id/reject - Reject loan
router.put('/:id/reject', async (req, res) => {
  try {
    const { id } = req.params;
    const { rejection_reason } = req.body;
    
    await pool.execute(
      `UPDATE loans 
       SET status = 'rejected', rejection_reason = ?
       WHERE id = ?`,
      [rejection_reason, id]
    );
    
    // Get loan details for activity log
    const [loan] = await pool.execute(
      `SELECT l.*, f.full_name FROM loans l 
       JOIN farmers f ON l.farmer_id = f.id 
       WHERE l.id = ?`,
      [id]
    );
    
    // Log rejection activity
    if (loan.length > 0) {
      try {
        await pool.execute(
          `INSERT INTO activity_logs (farmer_id, activity_type, activity_description, metadata)
           VALUES (?, 'loan_rejection', ?, ?)`,
          [
            loan[0].farmer_id, 
            `Loan application of ${loan[0].full_name} for ₱${loan[0].loan_amount} was rejected`,
            JSON.stringify({ loan_id: id, reason: rejection_reason })
          ]
        );
      } catch (logErr) {
        console.error('Error logging loan rejection:', logErr);
      }
    }
    
    res.json({ success: true, message: 'Loan rejected' });
  } catch (error) {
    console.error('Error rejecting loan:', error);
    res.status(500).json({ success: false, message: 'Failed to reject loan' });
  }
});

// POST /api/loans/:id/payment - Record loan payment
router.post('/:id/payment', async (req, res) => {
  try {
    const { id } = req.params;
    const { payment_date, amount, payment_method, reference_number, remarks, recorded_by } = req.body;
    
    if (!payment_date || !amount) {
      return res.status(400).json({ 
        success: false, 
        message: 'Missing required fields: payment_date, amount' 
      });
    }
    
    // Get current loan details
    const [loan] = await pool.execute('SELECT * FROM loans WHERE id = ?', [id]);
    
    if (loan.length === 0) {
      return res.status(404).json({ success: false, message: 'Loan not found' });
    }
    
    // Record payment
    await pool.execute(
      `INSERT INTO loan_payments 
       (loan_id, payment_date, amount, payment_method, reference_number, remarks, recorded_by)
       VALUES (?, ?, ?, ?, ?, ?, ?)`,
      [id, payment_date, amount, payment_method || 'cash', reference_number, remarks, recorded_by]
    );
    
    // Update loan totals
    const new_total_paid = parseFloat(loan[0].total_paid || 0) + parseFloat(amount);
    const new_remaining_balance = parseFloat(loan[0].loan_amount) - new_total_paid;
    const new_status = new_remaining_balance <= 0 ? 'paid' : 'active';
    
    await pool.execute(
      `UPDATE loans 
       SET total_paid = ?, remaining_balance = ?, status = ?
       WHERE id = ?`,
      [new_total_paid, new_remaining_balance, new_status, id]
    );
    
    // Log payment activity
    try {
      const [farmer] = await pool.execute('SELECT full_name FROM farmers WHERE id = ?', [loan[0].farmer_id]);
      await pool.execute(
        `INSERT INTO activity_logs (farmer_id, activity_type, activity_description, metadata)
         VALUES (?, 'loan_payment', ?, ?)`,
        [
          loan[0].farmer_id, 
          `${farmer[0]?.full_name} made a loan payment of ₱${amount}`,
          JSON.stringify({ loan_id: id, amount, remaining_balance: new_remaining_balance })
        ]
      );
    } catch (logErr) {
      console.error('Error logging loan payment:', logErr);
    }
    
    res.json({ 
      success: true, 
      message: 'Payment recorded successfully',
      remaining_balance: new_remaining_balance,
      status: new_status
    });
  } catch (error) {
    console.error('Error recording payment:', error);
    res.status(500).json({ success: false, message: 'Failed to record payment' });
  }
});

// GET /api/loans/stats - Get loan statistics
router.get('/stats/summary', async (req, res) => {
  try {
    const [stats] = await pool.execute(`
      SELECT 
        COUNT(*) as total_loans,
        SUM(CASE WHEN status = 'pending' THEN 1 ELSE 0 END) as pending_count,
        SUM(CASE WHEN status = 'approved' THEN 1 ELSE 0 END) as approved_count,
        SUM(CASE WHEN status = 'active' THEN 1 ELSE 0 END) as active_count,
        SUM(CASE WHEN status = 'paid' THEN 1 ELSE 0 END) as paid_count,
        SUM(CASE WHEN status = 'overdue' THEN 1 ELSE 0 END) as overdue_count,
        SUM(loan_amount) as total_amount_loaned,
        SUM(remaining_balance) as total_outstanding,
        SUM(total_paid) as total_collected
      FROM loans
    `);
    
    res.json({ success: true, stats: stats[0] });
  } catch (error) {
    console.error('Error fetching loan stats:', error);
    res.status(500).json({ success: false, message: 'Failed to fetch statistics' });
  }
});

module.exports = router;
