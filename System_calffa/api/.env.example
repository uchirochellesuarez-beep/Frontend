# ML API example env
# Default port for ML API (this service) is 5001 to avoid collisions with the Node backend
PORT=5001

# Path to trained model (joblib / pickle). If missing a simple deterministic fallback model
# will be used for local testing.
ML_MODEL_PATH=model/crop_profit_model.pkl
ML_CROP_MAPPING_PATH=model/crop_mapping.pkl

# Debugging
FLASK_DEBUG=true
